UPDATE PitchUsage
SET PitchType = CASE 
    WHEN PitchType = 'Four-Seam Fastball' THEN 'FF'
    WHEN PitchType = 'Sinker'             THEN 'SI'
    WHEN PitchType = 'Slider'             THEN 'SL'
    WHEN PitchType = 'Changeup'           THEN 'CH'
    WHEN PitchType = 'Curveball'          THEN 'CU'
    WHEN PitchType = 'Cutter'             THEN 'FC'
    WHEN PitchType = 'Splitter'           THEN 'FS'
    WHEN PitchType = 'Knuckle Curve'      THEN 'KC'
    WHEN PitchType = 'Sweeper'            THEN 'ST'
    ELSE PitchType -- Keeps the original value if no match is found
END;

